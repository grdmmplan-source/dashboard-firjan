# Variáveis de Ambiente — Dashboard Firjan
# Copie este arquivo para .env e configure conforme necessário
# (Atualmente, o projeto usa valores hardcoded — configure aqui se precisar)

# ====================================
# GOOGLE SHEETS (Saúde)
# ====================================
SAUDE_SHEET_ID=1bsovvrAr1a5vi9Ny4kujga732cfJp4zpRNTYphpxJos
SAUDE_GID=0

# ====================================
# SHAREPOINT URLs (SAC, Redes Sociais, Autonomia)
# ====================================
# Links públicos (sem credenciais)
SAC_URL=https://ddmadvbr-my.sharepoint.com/:x:/g/personal/fernanda_castro_grupoddm_com_br/IQCobMqlyAWfT7aBxT5EGURCAaAxahCZQjDD0eCyvVChMv0?download=1
REDES_URL=https://ddmadvbr-my.sharepoint.com/:x:/g/personal/fernanda_castro_grupoddm_com_br/IQCwxtAUa9lQS4BgM7YdpFrxAQd1Jys7p98gbp4QY43dnSg?download=1
AUTONOMIA_URL=https://ddmadvbr-my.sharepoint.com/:x:/g/personal/fernanda_castro_grupoddm_com_br/IQCwxtAUa9lQS4BgM7YdpFrxAQd1Jys7p98gbp4QY43dnSg?download=1

# ====================================
# CAMINHOS LOCAIS
# ====================================
# Pasta com arquivos Excel atualizáveis
PASTA_ATUALIZAVEIS=Arquivos/atualizaveis
# Pasta com de-para e bases de apoio
PASTA_BASES_APOIO=Arquivos/bases_apoio

# ====================================
# GITHUB
# ====================================
# Repositório remoto (usado por git push)
GITHUB_REPO=https://github.com/grdmmplan-source/dashboard-firjan.git
GITHUB_PAGES_URL=https://grdmmplan-source.github.io/dashboard-firjan/

# ====================================
# DEBUG & LOGGING
# ====================================
# Modo debug (verbose logs)
DEBUG=false
# Arquivo de log de erros do SAC
ERROS_SAC_LOG=erros_sac.txt

# ====================================
# TIMEOUTS (segundos)
# ====================================
# Timeout pra download do SharePoint
SHAREPOINT_TIMEOUT=60
# Timeout pra download do Google Sheets
SHEETS_TIMEOUT=40

# ====================================
# FILTROS DE DADOS
# ====================================
# Dias máximos de diferença (SAC outlier)
SAC_MAX_DELTA_DIAS=30
# Incluir dados futuros (testes)
INCLUDE_FUTURE_DATES=false
